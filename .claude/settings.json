{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cmake:*)",
      "Bash(just configure *)",
      "PowerShell(echo:*)",
      "Bash(just build *)",
      "Bash(git -C * log *)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git rebase *)",
      "Skill(grep)",
      "Skill(grep:*)",
      "Skill(run)",
      "Skill(run:*)",
      "WebSearch",
      "Bash(xargs *)",
      "PowerShell(cmake *)",
      "Bash(cmake *)",
      "Bash(sleep *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wsl gh run list *)",
      "Bash(wsl gh release list *)",
      "Bash(wsl gh run view *)",
      "Bash(wsl gh api *)",
      "Bash(wsl gh *)",
      "Bash(python -m aqt list-qt * )",
      "Bash(\"src/test_log_startup.exe\" *)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(time *)",
      "Bash(ctest *)"
    ]
  }
}
