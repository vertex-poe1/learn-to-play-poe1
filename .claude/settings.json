{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cmake:*)",
      "Bash(just configure *)",
      "PowerShell(echo:*)",
      "Bash(just build *)",
      "Bash(git -C * log *)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git rebase *)",
      "Skill(run)",
      "Skill(run:*)",
      "WebSearch",
      "Bash(xargs *)",
      "PowerShell(cmake *)"
    ]
  }
}
