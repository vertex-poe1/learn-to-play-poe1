{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "debug"],
      "problemMatcher": ["$gcc", "$msCompile"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CMake: Build (debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "debug"],
      "dependsOn": "CMake: Configure (debug)",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc", "$msCompile"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CTest: Run (debug)",
      "type": "shell",
      "command": "ctest",
      "args": ["--preset", "debug", "--output-on-failure"],
      "dependsOn": "CMake: Build (debug)",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CMake: Configure (windows-mingw)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "windows-mingw"],
      "problemMatcher": ["$gcc"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CMake: Build (windows-mingw)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "windows-mingw"],
      "dependsOn": "CMake: Configure (windows-mingw)",
      "problemMatcher": ["$gcc"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "just build (windows-msvc)",
      "type": "shell",
      "command": "just",
      "args": ["build"],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "just test (windows-msvc)",
      "type": "shell",
      "command": "just",
      "args": ["test"],
      "group": "test",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake",
      "args": ["-E", "rm", "-rf", "build", "dist"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
