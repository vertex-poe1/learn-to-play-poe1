// learn-to-play.code-workspace
// exists so:
// 1) we can disable all extensions in vscode and then enable them on a per-workspace basis (instead of profiles)
// 2) we can double click the file to open vscode as a convenience (then click reopen in WSL)
{
  "folders": [
    {
      "path": ".",
    },
  ],
  "settings": {
    "terminal.integrated.profiles.windows": {
      "Git Bash (MSVC x64)": {
        "path": "${env:ProgramFiles}/Git/bin/bash.exe",
        "args": ["--rcfile", "${workspaceFolder}/tools/msvc-env.sh", "-i"],
        "icon": "terminal-bash",
        "overrideName": true
      }
    },
    "terminal.integrated.defaultProfile.windows": "Git Bash (MSVC x64)",
    "claudeCode.environmentVariables": [{ "name": "NO_COLOR", "value": "1" }],
    "claudeCode.initialPermissionMode": "acceptEdits",
    "chat.tools.terminal.autoApprove": {
      "timeout": true,
    },    
    "chat.disableAIFeatures": false,
  },
}
